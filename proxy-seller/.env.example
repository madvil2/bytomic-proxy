# Seller wallet that RECEIVES USDC (Gateway balance). EVM address (0x...).
# This is the proxy operator's payout identity.
SELLER_WALLET_ADDRESS=0xYOUR_SELLER_WALLET

# Circle Gateway facilitator. Defaults to MAINNET if unset.
#   mainnet: https://gateway-api.circle.com
#   testnet: https://gateway-api-testnet.circle.com
FACILITATOR_URL=https://gateway-api-testnet.circle.com

# Networks the proxy accepts payment on (CAIP-2, comma separated).
#   Base mainnet:   eip155:8453   (what the Circle Claude kit buyer uses)
#   Base Sepolia:   eip155:84532
#   Arc testnet:    eip155:5042002
# Leave empty to accept ALL Gateway-supported networks (recommended).
NETWORKS=eip155:84532,eip155:5042002

# Price per proxied request, in USD.
PRICE=$0.001

# HTTP port.
PORT=3402

# Public base URL the agent reaches this service at (used in /catalog discovery).
# e.g. https://proxy.yourserver.com  or  http://localhost:3402
PUBLIC_URL=http://localhost:3402

# Optional dev/test bypass key. If set, a request with header
# `x-dev-bypass: <this value>` skips payment (proxy + ledger still run, receipt
# tagged payer="dev-bypass"). Leave UNSET in production. Lets you test the proxy
# without a funded Gateway balance.
# DEV_BYPASS_KEY=letmein
