{
  "name": "@agent-stack-ecosystem-kits/kit-core",
  "version": "0.0.0",
  "private": true,
  "description": "Framework-agnostic building blocks shared across the Circle Agent Stack kits: skill fetching, single-sourced model-facing tool descriptions, payment preflight/approval helpers, and a terminal theme.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./skill": "./src/skill.ts",
    "./theme": "./src/theme.ts",
    "./tools": "./src/tools.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@agent-stack-ecosystem-kits/circle-tools": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
