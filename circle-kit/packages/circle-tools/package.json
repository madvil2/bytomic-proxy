{
  "name": "@agent-stack-ecosystem-kits/circle-tools",
  "version": "0.0.0",
  "private": true,
  "description": "Framework-agnostic TypeScript wrappers around the Circle CLI (wallets, balances, service discovery, x402 payments).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
